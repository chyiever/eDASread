{\rtf1\ansi\ansicpg936\deff0{\fonttbl{\f0 SimSun;}}\viewkind4\uc1\pard\f0\fs22\n\u-257?eDAS\u25968?\u25454?\u26684?\u24335?\u19982?\u25968?\u25454?\u-29701?\u21462?\u-28817?\u20214?\u20351?\u29992?\u-29708?\u26126?\u-248?eDASread \u24403?\u21069?\u29256?\u26412?\u-247?\par\n\par\n\u31532?\u19968?\u31456? \u25991?\u26723?\u-29708?\u26126?\par\n\par\n\u26412?\u25991?\u26723?\u-26782?\u21521? eDAS \u25968?\u25454?\u20351?\u29992?\u20154?\u21592?\u12289?\u31639?\u27861?\u24320?\u21457?\u20154?\u21592?\u21644?\u-28817?\u20214?\u25805?\u20316?\u20154?\u21592?\u-244?\u-29708?\u26126? eDAS \u25968?\u25454?\u26684?\u24335?\u12289?eDASread \u30340?\u30028?\u-26782?\u32467?\u26500?\u12289?\u20132?\u20114?\u26041?\u24335?\u12289?\u28388?\u27874?\u19982?\u23548?\u20986?\u-30268?\u21017?\u12290?\u26412?\u25991?\u20197?\u24403?\u21069?\u20195?\u30721?\u23454?\u29616?\u20026?\u20934?\u12290?\par\n\par\n\u31532?\u20108?\u31456? eDAS \u25968?\u25454?\u26684?\u24335?\u-29708?\u26126?\par\n\par\n2.1 \u25991?\u20214?\u21629?\u21517?\u-30335?\u27714?\par\n- \u25991?\u20214?\u25193?\u23637?\u21517?\u24517?\u-26501?\u20026? `.bin`\u12290?\par\n- \u25991?\u20214?\u21517?\u24517?\u-26501?\u21253?\u21547?\u-28217?\u26679?\u29575?\u23383?\u27573?\u-244?\u20363?\u22914? `-2000Hz-`\u12290?\par\n- \u25991?\u20214?\u21517?\u24517?\u-26501?\u21253?\u21547?\u28857?\u25968?\u23383?\u27573?\u-244?\u20363?\u22914? `-0130pt-`\u12290?\par\n- \u25991?\u20214?\u21517?\u26411?\u23614?\u26102?\u-27148?\u25139?\u21487?\u-28663?\u-244?\u20363?\u22914? `-20260410T153045.123.bin`\u12290?\par\n\par\n2.2 \u23384?\u20648?\u32467?\u26500?\u19982?\u31867?\u22411?\par\n- \u21407?\u22987?\u25968?\u25454?\u31867?\u22411?\u-230?`int32`\u-248?4 \u23383?\u-32126?\u-247?\u12290?\par\n- \u21333?\u25991?\u20214?\u-28613?\u-28783?\u30697?\u-27083?\u-230?`frame_count x points`\u12290?\par\n- \u30913?\u30424?\u23384?\u20648?\u-26502?\u24207?\u-230?\u25353?\u24103?\u-28706?\u32493?\u-248?frame-major\u-247?\u12290?\par\n\par\n2.3 \u21333?\u20301?\u25442?\u31639?\par\n- \u26174?\u31034?/\u28388?\u27874?\u21069?\u23558?\u21407?\u22987?\u20540?\u25442?\u31639?\u20026?\u30456?\u20301?\u24359?\u24230?\u-230?\par\n  `phase_rad = raw_int32 x (pi / 32767)`\u12290?\par\n- \u23548?\u20986?\u28388?\u27874?\u21518?\u32467?\u26524?\u26102?\u20250?\u-28820?\u25442?\u22238? `int32` \u24182?\u20889?\u22238? bin \u25991?\u20214?\u12290?\par\n\par\n\u31532?\u19977?\u31456? \u-28817?\u20214?\u30028?\u-26782?\u19982?\u21151?\u-32515?\par\n\par\n3.1 \u20027?\u30028?\u-26782?\u24067?\u23616?\par\n- \u-26506?\u-28440?\u26631?\u-26472?\u26639?\u-230?\u24038?\u20391?\u26174?\u31034?\u-28817?\u20214? logo\u-244?\u20013?\u-28440?\u26174?\u31034?\u26631?\u-26472?\u12290?\par\n- \u29366?\u24577?\u26639?\u-230?\u26368?\u21491?\u20391?\u22266?\u23450?\u26174?\u31034?\u8220?\u31?\u20013?\u22269?\u31185?\u23398?\u-27038?\u21322?\u23548?\u20307?\u25152?\u24320?\u21457?\u8221?\u12290?\par\n- \u24038?\u20391?\u-230?\u25991?\u20214?\u27983?\u-30264?\u21306?\u-248?\u20998?\u-26507?\u12289?\u-29197?\u-26507?\u12289?home/end\u-247?\u12290?\par\n- \u21491?\u20391?\u-230?\u21442?\u25968?\u21306? + \u27874?\u24418?/\u26102?\u31354?\u22270?\u21306?\u12290?\par\n\par\n3.2 \u21442?\u25968?\u21306?\u24067?\u23616?\u-248?\u24403?\u21069?\u29256?\u26412?\u-247?\par\n- \u20004?\u21015?\u24067?\u23616?\u-230?\par\n  - \u24038?\u21015? `Display Range`\u12290?\par\n  - \u21491?\u21015? `Filter + Export`\u12290?\par\n- `Display Range` \u20013?\u20381?\u27425?\u21253?\u21547?\u-230?\par\n  - Point Start / Point End\par\n  - VMin / VMax\par\n  - Colormap\par\n  - Actions \u-30644?\u-230?Apply / Reset / Reset View / Back View / Zoom Out 2x / \u25351?\u23450?\u20301?\u32622?\u28857?\u26102?\u22495?\u32472?\u22270?\par\n\par\n3.3 \u26102?\u22495?\u22270?\u19982? time-space \u22270?\par\n- \u19978?\u26041?\u20026?\u8220?\u25351?\u23450?\u20301?\u32622?\u28857?\u26102?\u22495?\u27874?\u24418?\u8221?\u22270?\u12290?\par\n- \u19979?\u26041?\u20026? time-space \u22270?\u-248?\u21491?\u20391?\u20026?\u-32142?\u26631?\u-247?\u12290?\par\n- \u20004?\u22270?\u20849?\u29992?\u26102?\u-27148?\u-28812?\u-31997?\u22260?\u-248?\u-32684?\u21160?\u-247?\u12290?\par\n- \u20004?\u22270?\u22343?\u25903?\u25345?\u32553?\u25918?\u19982?\u26694?\u-28663?\u27983?\u-30264?\u12290?\par\n\par\n3.4 \u25351?\u23450?\u20301?\u32622?\u28857?\u-28781?\u20837?\u26694?\u20132?\u20114?\par\n- \u20165?\u20801?\u-29768?\u25972?\u25968?\u12290?\par\n- \u24517?\u-26501?\u20301?\u20110? `[Point Start, Point End]`\u12290?\par\n- \u-28781?\u20837?\u26694?\u-32678?\u28966?\u26102?\u21487?\u29992?\u-24800?\u26631?\u28378?\u-28818?\u25353?\u27493?\u-27265? \u177?1 \u-29693?\u25972?\u12290?\par\n\par\n3.5 \u28388?\u27874?\u21151?\u-32515?\par\n- \u25903?\u25345? `none / lowpass / highpass / bandpass`\u12290?\par\n- \u-26479?\u29575?\u32422?\u26463?\u-28555?\u24490? Nyquist\u-248?\u-28217?\u26679?\u29575?\u19968?\u21322?\u-247?\u12290?\par\n- \u28388?\u27874?\u27839?\u26102?\u-27148?\u-28812?\u23545?\u27599?\u20010?\u31354?\u-27148?\u28857?\u25191?\u-30644?\u12290?\par\n\par\n3.6 \u23548?\u20986?\u-30268?\u21017?\par\n- \u23548?\u20986?\u23545?\u-29599?\u26159?\u24403?\u21069?\u21487?\u-30266?\u31383?\u21475?\u-244?\u19981?\u26159?\u20840?\u25991?\u20214?\u12290?\par\n- \u27178?\u21521?\u-31997?\u22260?\u25353?\u26102?\u-27148?\u25442?\u31639?\u20026?\u24103?\u32034?\u24341?\u12290?\par\n- \u32437?\u21521?\u-31997?\u22260?\u25353?\u28857?\u32034?\u24341?\u25130?\u21462?\u12290?\par\n- \u23548?\u20986?\u25991?\u20214?\u21629?\u21517?\u-30268?\u21017?\u-230?\par\n  `eDAS-<sample-rate>Hz-<point-count>pt-<start-time>.bin`\par\n\par\n\u31532?\u22235?\u31456? \u25805?\u20316?\u27969?\u31243?\par\n\par\n1. \u21551?\u21160?\u-28817?\u20214?\u24182?\u-28663?\u25321?\u25968?\u25454?\u30446?\u24405?\u12290?\par\n2. \u22312?\u24038?\u20391?\u21015?\u-30616?\u-28663?\u25321?\u25991?\u20214?\u12290?\par\n3. \u-29762?\u32622?\u28857?\u-31997?\u22260?\u12289?\u-32142?\u26631?\u-31997?\u22260?\u12289?colormap\u12289?\u28388?\u27874?\u21442?\u25968?\u12290?\par\n4. \u22312?\u8220?\u25351?\u23450?\u20301?\u32622?\u28857?\u26102?\u22495?\u32472?\u22270?\u8221?\u-28781?\u20837?\u26694?\u20013?\u-28781?\u20837?\u25110?\u28378?\u-28818?\u-29693?\u25972?\u28857?\u21495?\u12290?\par\n5. \u28857?\u20987? Apply \u26356?\u26032?\u26174?\u31034?\u12290?\par\n6. \u20351?\u29992?\u-24800?\u26631?\u32553?\u25918?\u12289?Reset View\u12289?Back View\u12289?Zoom Out 2x \u27983?\u-30264?\u12290?\par\n7. \u-28663?\u25321?\u23548?\u20986?\u30446?\u24405?\u-244?\u28857?\u20987? Export Current View\u12290?\par\n\par\n\u31532?\u20116?\u31456? \u24120?\u-30271?\u-27154?\u-26472?\par\n\par\n- \u26080?\u27861?\u-29754?\u21035?\u-28217?\u26679?\u29575?/\u28857?\u25968?\u-230?\u25991?\u20214?\u21517?\u32570?\u23569? `Hz` \u25110? `pt` \u23383?\u27573?\u12290?\par\n- Invalid point range\u-230?Point Start/End \u-29762?\u32622?\u-29302?\u30028?\u25110?\u-26502?\u24207?\u-27367?\u-29713?\u12290?\par\n- \u25351?\u23450?\u20301?\u32622?\u28857?\u26080?\u25928?\u-230?\u19981?\u26159?\u25972?\u25968?\u25110?\u19981?\u22312? Point Start~Point End \u-31997?\u22260?\u12290?\par\n- \u23548?\u20986?\u20026?\u31354?\u-230?\u24403?\u21069?\u-30266?\u31383?\u27809?\u26377?\u26377?\u25928?\u24103?\u25110?\u28857?\u12290?\par\n\par\n\u31532?\u20845?\u31456? \u29256?\u26435?\u19982?\u20813?\u-29405?\u22768?\u26126?\par\n\par\n\u-28817?\u20214?\u12289?\u25991?\u26723?\u19982?\u30456?\u20851?\u23454?\u29616?\u24402?\u26435?\u21033?\u20154?\u25152?\u26377?\u12290?\u26410?\u32463?\u25480?\u26435?\u19981?\u24471?\u22797?\u21046?\u12289?\u20462?\u25913?\u12289?\u20256?\u25773?\u25110?\u29992?\u20110?\u-29307?\u25480?\u26435?\u22330?\u26223?\u12290?\par\n\par\n\u-28817?\u20214?\u-28781?\u20986?\u21463?\u21407?\u22987?\u25968?\u25454?\u-29400?\u-28209?\u12289?\u21629?\u21517?\u-30268?\u-31997?\u12289?\u21442?\u25968?\u-29762?\u32622?\u21644?\u25805?\u20316?\u26041?\u24335?\u24433?\u21709